#!/usr/bin/env python3
"""
Wrapper around ~/.local/bin/shotout that writes recording status to
/tmp/shotout-status so the GNOME Shell extension can display
a visual indicator in the top bar.

Assign this as the hotkey command instead of shotout directly.
The original script is never modified.

Modes:
    (no args)   toggle recording / stop + transcribe
    --watchdog  internal: background time-limit / cancel watcher
    --retry     re-transcribe the last recording that failed
    --discard   drop the last failed recording without transcribing
"""
import json
import os
import signal
import subprocess
import sys
import time
from datetime import date
from pathlib import Path

PIDFILE       = "/tmp/shotout.pid"
START_FILE    = "/tmp/shotout-start"
LIMIT_FILE    = "/tmp/shotout-limit"
CANCEL_FILE   = "/tmp/shotout-cancel"
STATUS_FILE   = "/tmp/shotout-status"
PENDING_AUDIO = "/tmp/shotout-pending.wav"   # last recording that failed transcription
PENDING_SECS  = "/tmp/shotout-pending-secs"  # its duration, for stats on a successful retry
STATS_FILE    = Path.home() / ".local/share/shotout/stats.json"
ORIGINAL      = os.path.expanduser("~/.local/bin/shotout")
SHIMS_DIR     = os.path.expanduser("~/.local/lib/shotout-shims")

TAIL_DELAY         = 1.5      # seconds to keep recording after stop hotkey
MAX_RECORDING_SECS = 5 * 60  # safeguard: auto-stop after this many seconds

# Exit codes returned by the original shotout script
EXIT_OK     = 0   # transcribed and pasted
EXIT_FAILED = 1   # transcription failed, audio preserved for retry
EXIT_NOOP   = 2   # nothing to do

# Prepend shims dir so fake notify-send intercepts calls from the original script
os.environ["PATH"] = SHIMS_DIR + ":" + os.environ.get("PATH", "")

TEMP_FILES = (START_FILE, LIMIT_FILE, CANCEL_FILE)


def write_status(status: str) -> None:
    try:
        with open(STATUS_FILE, "w") as f:
            f.write(status)
    except OSError:
        pass


def cleanup_temp_files() -> None:
    for f in TEMP_FILES:
        try:
            os.remove(f)
        except OSError:
            pass


def remove_quietly(path: str) -> None:
    try:
        os.remove(path)
    except OSError:
        pass


def kill_sox() -> None:
    """Kill the sox process recorded in PIDFILE without transcribing."""
    try:
        with open(PIDFILE) as f:
            pid = int(f.read().strip())
        os.kill(pid, signal.SIGTERM)
    except (OSError, ValueError, ProcessLookupError):
        pass
    try:
        os.remove(PIDFILE)
    except OSError:
        pass


def write_stats(duration_secs: int) -> None:
    today = date.today().isoformat()
    stats: dict = {}
    if STATS_FILE.exists():
        try:
            stats = json.loads(STATS_FILE.read_text())
        except Exception:
            pass
    if today not in stats:
        stats[today] = {"requests": 0, "seconds": 0}
    stats[today]["requests"] += 1
    stats[today]["seconds"] += max(0, duration_secs)
    STATS_FILE.parent.mkdir(parents=True, exist_ok=True)
    STATS_FILE.write_text(json.dumps(stats, indent=2))


def finish(returncode: int, duration: int) -> None:
    """Translate the original script's exit code into an indicator status."""
    if returncode == EXIT_FAILED:
        # Remember the recording length so a later successful retry can be counted
        try:
            with open(PENDING_SECS, "w") as f:
                f.write(str(max(0, duration)))
        except OSError:
            pass
        write_status("error")
    else:
        if returncode == EXIT_OK:
            write_stats(duration)
        write_status("idle")


def run_watchdog() -> None:
    """Detached process: polls every second to handle cancel or auto-stop."""
    for _ in range(MAX_RECORDING_SECS):
        time.sleep(1)

        if not os.path.exists(PIDFILE):
            return  # stopped normally by user hotkey

        if os.path.exists(CANCEL_FILE):
            # User cancelled via extension click — kill sox, no transcription
            kill_sox()
            write_status("idle")
            cleanup_temp_files()
            return

    # Time limit reached — auto-stop with transcription
    if not os.path.exists(PIDFILE):
        return
    write_status("recognizing")
    returncode = EXIT_OK
    try:
        returncode = subprocess.run([ORIGINAL]).returncode
    finally:
        finish(returncode, MAX_RECORDING_SECS)
        cleanup_temp_files()


def handle_retry() -> None:
    """Re-transcribe the last failed recording (manual, unlimited)."""
    if not os.path.exists(PENDING_AUDIO):
        write_status("idle")
        return
    write_status("recognizing")
    returncode = EXIT_OK
    try:
        returncode = subprocess.run([ORIGINAL, "--retry"]).returncode
    finally:
        if returncode == EXIT_FAILED:
            write_status("error")
        else:
            if returncode == EXIT_OK:
                secs = 0
                try:
                    secs = int(Path(PENDING_SECS).read_text().strip())
                except Exception:
                    pass
                write_stats(secs)
            remove_quietly(PENDING_SECS)
            write_status("idle")


def handle_discard() -> None:
    """Drop the last failed recording without transcribing."""
    remove_quietly(PENDING_AUDIO)
    remove_quietly(PENDING_SECS)
    write_status("idle")


def main():
    if len(sys.argv) > 1:
        mode = sys.argv[1]
        if mode == "--watchdog":
            run_watchdog()
            return
        if mode == "--retry":
            handle_retry()
            return
        if mode == "--discard":
            handle_discard()
            return

    if os.path.exists(PIDFILE):
        # Recording is already active — wait for tail, then stop and transcribe
        duration = 0
        try:
            with open(START_FILE) as f:
                duration = int(time.time() - float(f.read()) + TAIL_DELAY)
        except Exception:
            pass

        time.sleep(TAIL_DELAY)  # keep recording so last words are captured

        if not os.path.exists(PIDFILE):
            # Cancelled by watchdog during tail delay — nothing to do
            write_status("idle")
            cleanup_temp_files()
            return

        write_status("recognizing")
        returncode = EXIT_OK
        try:
            returncode = subprocess.run([ORIGINAL] + sys.argv[1:]).returncode
        finally:
            finish(returncode, duration)
            cleanup_temp_files()
    else:
        # No recording active — start one. Starting discards any previous
        # un-transcribed recording: only the most recent one is ever kept.
        remove_quietly(PENDING_SECS)
        try:
            with open(START_FILE, "w") as f:
                f.write(str(time.time()))
        except OSError:
            pass

        # Tell the extension what the recording limit is (for warning pulse)
        try:
            with open(LIMIT_FILE, "w") as f:
                f.write(str(MAX_RECORDING_SECS))
        except OSError:
            pass

        write_status("recording")

        # Launch watchdog as detached background process
        subprocess.Popen(
            [sys.executable, os.path.abspath(__file__), "--watchdog"],
            start_new_session=True,
            close_fds=True,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )

        subprocess.run([ORIGINAL] + sys.argv[1:])
        # Status intentionally stays "recording" until next invocation


if __name__ == "__main__":
    main()
